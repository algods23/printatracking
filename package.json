{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "name": "printa-signages",
    "version": "1.0.2",
    "description": "Professional Signages & Stickers Management System",
    "main": "electron/main.cjs",
    "homepage": "",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "electron": "electron .",
        "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "desktop:prepare": "powershell -ExecutionPolicy Bypass -File scripts/prepare-desktop.ps1",
        "desktop:build": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
        "electron-build": "npm run build && npm run desktop:prepare && electron-builder",
        "electron-build-win": "npm run build && npm run desktop:prepare && electron-builder --win",
        "electron-build-mac": "npm run build && electron-builder --mac",
        "electron-build-linux": "npm run build && electron-builder --linux",
        "electron-pack": "npm run build && electron-builder --dir",
        "dist": "npm run electron-build"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "electron": "^31.7.7",
        "electron-builder": "^24.6.4",
        "electron-is-dev": "^3.0.0",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "wait-on": "^7.0.1"
    },
    "dependencies": {
        "chart.js": "^4.4.0",
        "lucide": "latest"
    },
    "build": {
        "appId": "com.printa.signages",
        "productName": "Printa Signages",
        "directories": {
            "buildResources": "assets"
        },
        "files": [
            "electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "desktop/build/laravel-app",
                "to": "laravel-app"
            },
            {
                "from": "desktop/runtime",
                "to": "runtime",
                "filter": [
                    "**/*",
                    "!README.md"
                ]
            },
            {
                "from": "assets",
                "to": "assets",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Printa Signages",
            "runAfterFinish": true,
            "deleteAppDataOnUninstall": false
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ]
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ]
        }
    }
}
